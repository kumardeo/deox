{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "lib": ["ES2022", "ESNext"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": [".", "../src"]
}
