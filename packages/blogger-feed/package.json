{
  "name": "@deox/blogger-feed",
  "version": "0.0.11",
  "private": false,
  "description": "A blogger feed API client.",
  "keywords": [
    "blogger",
    "blogger-feed"
  ],
  "license": "MIT",
  "author": {
    "name": "Deo Kumar",
    "url": "https://github.com/kumardeo"
  },
  "homepage": "https://github.com/kumardeo/deox/tree/main/packages/blogger-feed#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kumardeo/deox",
    "directory": "packages/blogger-feed"
  },
  "bugs": {
    "url": "https://github.com/kumardeo/deox/issues"
  },
  "scripts": {
    "lint": "biome lint ./src",
    "check": "biome check ./src",
    "check:types": "tsc --noEmit",
    "build": "NODE_ENV=production tsdown",
    "dev": "NODE_ENV=development tsdown --watch",
    "playground": "vite ./dev"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "devDependencies": {
    "tsdown": "catalog:default",
    "vite": "catalog:default"
  }
}
